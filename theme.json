{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        { "slug": "background", "name": "Background", "color": "#f0d0d0" },
        { "slug": "foreground", "name": "Foreground", "color": "#1a1a1a" },
        { "slug": "primary", "name": "Primary", "color": "#6d003e" },
        { "slug": "secondary", "name": "Secondary", "color": "#ffb606" },
        { "slug": "tertiary", "name": "Tertiary", "color": "#442e66" },
        { "slug": "muted", "name": "Muted", "color": "#686868" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "var(--font-merriweather), Georgia, serif"
        },
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "var(--font-montserrat), \"Helvetica Neue\", sans-serif"
        }
      ]
    }
  }
}
