{
  "name": "ragbaz-articulate-storefront",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "theme:css": "node scripts/generate-theme-css.mjs",
    "test:theme": "node --test scripts/generate-theme-css.test.mjs",
    "predev": "npm run theme:css",
    "prebuild": "npm run theme:css",
    "prestart": "npm run theme:css",
    "precf:build": "npm run theme:css",
    "config": "./configure.sh",
    "doc": "node scripts/render-doc.cjs",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build && wrangler deploy",
    "lint": "eslint .",
    "prettier": "prettier --write .",
    "plugin:build": "npm run build --workspace ragbaz-articulate-plugin",
    "plugin:copy": "npm run plugin:build && mkdir -p public/downloads/ragbaz-articulate && cp packages/ragbaz-articulate-plugin/dist/Ragbaz-Articulate.zip public/downloads/ragbaz-articulate/",
    "test": "node --test tests/**/*.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "next": "^15.5.13",
    "prettier": "^3.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opennextjs/cloudflare": "^1.4.0",
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.2.1",
    "raw-loader": "^4.0.2",
    "tailwindcss": "^4",
    "wrangler": "^4.70.0"
  }
}
