{
  "name": "ragbaz-bridge-storefront",
  "version": "0.1.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/patch-opennext.mjs",
    "theme:css": "node scripts/generate-theme-css.mjs",
    "test:theme": "node --test scripts/generate-theme-css.test.mjs",
    "predev": "npm run theme:css",
    "prebuild": "npm run theme:css",
    "postbuild": "npm run plugin:copy",
    "prestart": "npm run theme:css",
    "precf:build": "npm run theme:css",
    "config": "./configure.sh",
    "doc": "node scripts/render-doc.cjs",
    "dev": "next dev --turbopack",
    "build": "node scripts/build-with-lock.mjs next build",
    "start": "next start",
    "cf:build": "node scripts/build-with-lock.mjs opennextjs-cloudflare build && node scripts/patch-cf-worker.mjs",
    "cf:preview": "node scripts/build-with-lock.mjs opennextjs-cloudflare build && node scripts/patch-cf-worker.mjs && wrangler dev",
    "cf:deploy": "node scripts/build-with-lock.mjs opennextjs-cloudflare build && node scripts/patch-cf-worker.mjs && wrangler deploy",
    "perf:budget": "node scripts/check-performance-budgets.mjs",
    "wasm:upload": "bash scripts/upload-wasm-to-r2.sh",
    "lint": "eslint .",
    "prettier": "prettier --write .",
    "plugin:build": "npm run build --workspace ragbaz-bridge-plugin",
    "plugin:copy": "npm run plugin:build && node scripts/copy-plugin-zip.mjs",
    "test": "node --experimental-test-module-mocks --loader ./tests/path-alias-loader.mjs --test tests/**/*.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@cf-wasm/photon": "^0.3.4",
    "@jsquash/avif": "^2.1.1",
    "next": "^16.2.0",
    "prettier": "^3.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^20.4.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@aws-sdk/xml-builder": "3.972.16",
    "tar": ">=7.5.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opennextjs/cloudflare": "^1.4.0",
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.0",
    "raw-loader": "^4.0.2",
    "tailwindcss": "^4",
    "wrangler": "^4.70.0"
  }
}
