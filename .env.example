# WordPress
NEXT_PUBLIC_WORDPRESS_URL=https://fictional-wordpress.example.test
NEXT_PUBLIC_SITE_URL=https://www.example.com
NEXT_PUBLIC_TENANT_KEY=default
# Comma-separated legacy domains that should be treated as pseudo-external aliases
# NEXT_PUBLIC_PSEUDO_EXTERNAL_HOSTS=legacy.example
# GraphQL debug logging (set to 1 temporarily when troubleshooting)
NEXT_PUBLIC_WORDPRESS_GRAPHQL_DEBUG=0
WORDPRESS_GRAPHQL_DEBUG=0
# Artificial GraphQL delay (ms) for diagnostics; keep 0 in production
GRAPHQL_DELAY_MS=0
# Option A: Bearer token (JWT/plugin token)
WORDPRESS_GRAPHQL_AUTH_TOKEN=wp_fake_admin_token_for_example_only
# Option B: Basic auth (WordPress Application Password)
WORDPRESS_GRAPHQL_USERNAME=admin@example.test
WORDPRESS_GRAPHQL_APPLICATION_PASSWORD=alpha bravo charlie delta echo foxtrot
# Set to 1 if WPGraphQL Content Blocks plugin is installed
# NEXT_PUBLIC_WORDPRESS_EDITOR_BLOCKS=1
# Note: Event CPT and LearnPress are auto-detected via GraphQL introspection

# Auth / Admin
AUTH_SECRET=replace-with-a-long-random-secret
ADMIN_EMAILS=admin.one@example.test,admin.two@example.test
ADMIN_PASSWORDS=orbit-maple-914,harbor-lantern-263

# Course Access
COURSE_ACCESS_BACKEND=cloudflare-kv
COURSE_ACCESS_STORE=cloudflare
USER_STORE_BACKEND=cloudflare
DIGITAL_ACCESS_STORE=cloudflare
# DEFAULT_COURSE_FEE_CENTS — optional; if unset, price must be configured per course in admin UI
DEFAULT_COURSE_FEE_CURRENCY=SEK

# Stripe
STRIPE_SECRET_KEY=sk_test_fake_key_example_only
STRIPE_WEBHOOK_SECRET=whsec_fake_secret_example_only

# Cloudflare KV/API
CLOUDFLARE_ACCOUNT_ID=fake_account_id
CF_API_TOKEN=fake_cloudflare_api_token
CF_KV_NAMESPACE_ID=fake_kv_namespace_id
CF_KV_KEY=course-access
CF_USERS_KV_KEY=users
CF_DIGITAL_ACCESS_KV_KEY=digital-access

# Cloudflare Analytics
# CF_ZONE_ID — set when using a custom domain routed through Cloudflare (full analytics: referrers, page views, unique visitors)
# Without CF_ZONE_ID, basic Workers analytics (request counts, errors) are used via CLOUDFLARE_ACCOUNT_ID
# CF_ZONE_ID=fake_zone_id
# CF_WORKER_NAME — defaults to wrangler.jsonc "name" field; override if different
# CF_WORKER_NAME=articulate-learnpress-stripe

# Optional OAuth providers
AUTH_GOOGLE_ID=fake_google_client_id
AUTH_GOOGLE_SECRET=fake_google_client_secret
AUTH_FACEBOOK_ID=fake_facebook_app_id
AUTH_FACEBOOK_SECRET=fake_facebook_app_secret
AUTH_MICROSOFT_ENTRA_ID_ID=fake_microsoft_client_id
AUTH_MICROSOFT_ENTRA_ID_SECRET=fake_microsoft_client_secret
AUTH_MICROSOFT_ENTRA_ID_TENANT=common
AUTH_APPLE_ID=fake_apple_service_id
AUTH_APPLE_SECRET=fake_apple_client_secret

# File upload backend: "wordpress" (default), "r2" (Cloudflare R2), or "s3" (any S3-compatible)
# S3 is optional and disabled by default on this platform; enable explicitly:
# ENABLE_S3_UPLOAD=1
# UPLOAD_BACKEND=r2
# For R2: uses CLOUDFLARE_ACCOUNT_ID above for endpoint; for S3: set S3_ENDPOINT
# S3_ACCESS_KEY_ID=fake_access_key
# S3_SECRET_ACCESS_KEY=fake_secret_key
# S3_BUCKET_NAME=my-uploads
# S3_PUBLIC_URL=https://pub-xxxx.r2.dev
# S3_REGION=auto
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_FORCE_PATH_STYLE=0

# Optional image optimization on Cloudflare
CLOUDFLARE_IMAGE_RESIZING=1

# Password reset email (Resend)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# GitHub deploy (for admin UI re-deploy button)
# GITHUB_DEPLOY_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GITHUB_REPO=owner/repo-name
# GITHUB_DEPLOY_WORKFLOW=deploy.yml
