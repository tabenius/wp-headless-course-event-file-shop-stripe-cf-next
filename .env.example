# WordPress
NEXT_PUBLIC_WORDPRESS_URL=https://fictional-wordpress.example.test
# Option A: Bearer token (JWT/plugin token)
WORDPRESS_GRAPHQL_AUTH_TOKEN=wp_fake_admin_token_for_example_only
# Option B: Basic auth (WordPress Application Password)
WORDPRESS_GRAPHQL_USERNAME=admin@example.test
WORDPRESS_GRAPHQL_APPLICATION_PASSWORD=alpha bravo charlie delta echo foxtrot
# Set to 1 if WPGraphQL Content Blocks plugin is installed
# NEXT_PUBLIC_WORDPRESS_EDITOR_BLOCKS=1
# Set to 1 if Event CPT is registered in WPGraphQL
# NEXT_PUBLIC_WORDPRESS_EVENT_CPT=1
# Set to 1 to enable LearnPress course listing and detail pages
# NEXT_PUBLIC_WORDPRESS_LEARNPRESS=1

# Auth / Admin
AUTH_SECRET=replace-with-a-long-random-secret
ADMIN_EMAILS=admin.one@example.test,admin.two@example.test
ADMIN_PASSWORDS=orbit-maple-914,harbor-lantern-263

# Course Access
COURSE_ACCESS_BACKEND=wordpress
COURSE_ACCESS_STORE=cloudflare
USER_STORE_BACKEND=cloudflare
DIGITAL_ACCESS_STORE=cloudflare
DEFAULT_COURSE_FEE_CENTS=4999
DEFAULT_COURSE_FEE_CURRENCY=usd

# Stripe
STRIPE_SECRET_KEY=sk_test_fake_key_example_only
STRIPE_WEBHOOK_SECRET=whsec_fake_secret_example_only

# Cloudflare KV/API
CF_ACCOUNT_ID=fake_account_id
CF_API_TOKEN=fake_cloudflare_api_token
CF_KV_NAMESPACE_ID=fake_kv_namespace_id
CF_KV_KEY=course-access
CF_USERS_KV_KEY=users
CF_DIGITAL_ACCESS_KV_KEY=digital-access

# Optional OAuth providers
AUTH_GOOGLE_ID=fake_google_client_id
AUTH_GOOGLE_SECRET=fake_google_client_secret
AUTH_FACEBOOK_ID=fake_facebook_app_id
AUTH_FACEBOOK_SECRET=fake_facebook_app_secret
AUTH_MICROSOFT_ENTRA_ID_ID=fake_microsoft_client_id
AUTH_MICROSOFT_ENTRA_ID_SECRET=fake_microsoft_client_secret
AUTH_MICROSOFT_ENTRA_ID_TENANT=common
AUTH_APPLE_ID=fake_apple_service_id
AUTH_APPLE_SECRET=fake_apple_client_secret

# Optional image optimization on Cloudflare
CLOUDFLARE_IMAGE_RESIZING=1
