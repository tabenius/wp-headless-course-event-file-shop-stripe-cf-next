# WordPress
NEXT_PUBLIC_WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_GRAPHQL_AUTH_TOKEN=

# Auth / Admin
AUTH_SECRET=change-this-to-a-strong-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Course Access
COURSE_ACCESS_BACKEND=wordpress
COURSE_ACCESS_STORE=cloudflare
USER_STORE_BACKEND=cloudflare
DEFAULT_COURSE_FEE_CENTS=4999
DEFAULT_COURSE_FEE_CURRENCY=usd

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Cloudflare KV/API
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_KV_NAMESPACE_ID=
CF_KV_KEY=course-access
CF_USERS_KV_KEY=users

# Optional OAuth providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT=common
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Optional image optimization on Cloudflare
CLOUDFLARE_IMAGE_RESIZING=1
